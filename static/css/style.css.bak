* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: #0b0e11;
    color: #e8edf2;
    display: flex;
    min-height: 100vh;
}

.sidebar {
    width: 220px;
    background: #141a20;
    border-right: 1px solid #1e252b;
    display: flex;
    flex-direction: column;
    padding: 20px 0;
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    transition: transform 0.3s ease;
    z-index: 1000;
}

.sidebar .logo {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    padding: 0 20px 20px;
    border-bottom: 1px solid #1e252b;
    margin-bottom: 16px;
}

.sidebar .logo i {
    color: #2d7aff;
    margin-right: 8px;
}

.sidebar nav a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    color: #8b9bb5;
    text-decoration: none;
    font-size: 0.9rem;
    transition: 0.2s;
    border-left: 3px solid transparent;
}

.sidebar nav a i {
    width: 20px;
    text-align: center;
}

.sidebar nav a:hover,
.sidebar nav a.active {
    background: #1e252b;
    color: #fff;
    border-left-color: #2d7aff;
}

.sidebar .footer-side {
    margin-top: auto;
    padding: 16px 20px;
    border-top: 1px solid #1e252b;
    font-size: 0.75rem;
    color: #5a6b7e;
}

.main {
    margin-left: 220px;
    flex: 1;
    padding: 20px 28px;
}

.topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 16px;
    border-bottom: 1px solid #1e252b;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
}

.topbar .left {
    display: flex;
    align-items: center;
    gap: 14px;
}

.topbar h1 {
    font-size: 1.4rem;
    font-weight: 600;
}

.topbar .user {
    display: flex;
    align-items: center;
    gap: 12px;
}

.topbar .user span {
    color: #8b9bb5;
}

.topbar .user .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2d7aff, #1a5fd9);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: #fff;
}

.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
}

.card {
    background: #141a20;
    border: 1px solid #1e252b;
    border-radius: 12px;
    padding: 18px 20px;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.card:hover {
    border-color: #2d7aff;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(45, 122, 255, 0.12);
}

.card .label {
    font-size: 0.8rem;
    color: #8b9bb5;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.card .label i {
    margin-right: 6px;
    color: #2d7aff;
}

.card .value {
    font-size: 2rem;
    font-weight: 700;
    margin-top: 4px;
}

.card .change {
    font-size: 0.75rem;
    color: #4caf50;
    margin-top: 4px;
}

.chart-container {
    background: #141a20;
    border: 1px solid #1e252b;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 28px;
}

.chart-container h3 {
    margin-bottom: 16px;
    font-weight: 500;
    font-size: 1rem;
}

.chart-container h3 i {
    color: #2d7aff;
    margin-right: 8px;
}

.chart-container canvas {
    max-height: 220px;
    width: 100% !important;
}

.table-wrap {
    background: #141a20;
    border: 1px solid #1e252b;
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
}

.table-wrap h3 {
    margin-bottom: 16px;
    font-weight: 500;
    font-size: 1rem;
}

.table-wrap h3 i {
    color: #2d7aff;
    margin-right: 8px;
}

table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
}

th {
    text-align: left;
    padding: 10px 8px;
    color: #8b9bb5;
    font-weight: 500;
    border-bottom: 1px solid #1e252b;
}

td {
    padding: 10px 8px;
    border-bottom: 1px solid #1e252b;
    color: #b0c4de;
}

td i {
    color: #2d7aff;
    margin-right: 6px;
}

.status {
    display: inline-block;
    padding: 2px 12px;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
}

.status.active {
    background: #1e3a2a;
    color: #4caf50;
}

.status.inactive {
    background: #3a1e1e;
    color: #ef5350;
}

.hamburger {
    display: none;
    background: none;
    border: none;
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
}

.login-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    width: 100%;
    background: #0b0e11;
}

.login-box {
    background: #141a20;
    border: 1px solid #1e252b;
    border-radius: 16px;
    padding: 40px 32px;
    width: 340px;
    max-width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
}

.login-box h2 {
    font-size: 1.6rem;
    margin-bottom: 4px;
}

.login-box h2 i {
    color: #2d7aff;
    margin-right: 8px;
}

.login-box p {
    color: #8b9bb5;
    font-size: 0.9rem;
    margin-bottom: 20px;
}

.login-box input {
    width: 100%;
    padding: 12px 14px;
    background: #0b0e11;
    border: 1px solid #1e252b;
    border-radius: 8px;
    color: #fff;
    margin-bottom: 12px;
    font-size: 0.95rem;
    transition: 0.2s;
}

.login-box input:focus {
    outline: none;
    border-color: #2d7aff;
}

.login-box button {
    width: 100%;
    padding: 12px;
    background: linear-gradient(135deg, #2d7aff, #1a5fd9);
    border: none;
    border-radius: 8px;
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: 0.3s;
}

.login-box button:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(45, 122, 255, 0.4);
}

.erro-msg {
    background: #3a1e1e;
    color: #ef5350;
    padding: 10px 14px;
    border-radius: 8px;
    margin-bottom: 16px;
    border-left: 4px solid #ef5350;
}

@media (max-width: 768px) {
    .sidebar {
        transform: translateX(-100%);
    }

    .sidebar.open {
        transform: translateX(0);
    }

    .main {
        margin-left: 0;
        padding: 16px;
    }

    .hamburger {
        display: block;
    }

    .topbar h1 {
        font-size: 1.1rem;
    }
}