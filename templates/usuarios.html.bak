{% extends "base.html" %}
{% block title %}Usuários{% endblock %}
{% block page_title %}Usuários{% endblock %}
{% block content %}
<div class="table-wrap">
    <h3><i class="fas fa-users"></i> Lista de usuários</h3>
    <table>
        <thead>
            <tr><th>Nome</th><th>Email</th><th>Status</th><th>Assinatura</th>
            {% if session.nivel == 'admin' %}<th>Ação</th>{% endif %}</tr>
        </thead>
        <tbody>
            {% for u in usuarios %}
            <tr>
                <td><i class="fas fa-user-circle"></i> {{ u.nome }}</td>
                <td>{{ u.email }}</td>
                <td><span class="status {{ 'active' if u.status == 'Ativo' else 'inactive' }}">{{ u.status }}</span></td>
                <td>{{ u.assinatura }}</td>
                {% if session.nivel == 'admin' %}
                <td><a href="{{ url_for('remover_usuario', index=loop.index0) }}" <button class="btn-remover" onclick="abrirModalRemover('{{ url_for('remover_usuario', index=loop.index0) }}', '{{ u.nome }}')">Remover</button>
<div id="modalRemover" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);z-index:9999;display:flex;align-items:center;justify-content:center;">
    <div style="background:#141a20;border:1px solid #1e252b;border-radius:16px;padding:32px 40px;max-width:400px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.6);">
        <h3 style="margin-bottom:8px;"><i class="fas fa-exclamation-triangle" style="color:#ef5350;margin-right:10px;"></i>Remover usuário</h3>
        <p style="color:#8b9bb5;margin-bottom:20px;">Tem certeza que deseja remover <strong id="modalNomeUsuario"></strong>? Essa ação não pode ser desfeita.</p>
        <div style="display:flex;gap:12px;justify-content:flex-end;">
            <button onclick="fecharModalRemover()" style="background:transparent;border:1px solid #1e252b;border-radius:8px;padding:8px 20px;color:#8b9bb5;cursor:pointer;">Cancelar</button>
            <a id="modalLinkRemover" href="#" class="btn-remover" style="padding:8px 24px;text-decoration:none;display:inline-block;background:#ef5350;color:#fff;border-radius:8px;border:none;cursor:pointer;">Remover</a>
        </div>
    </div>
</div>

<script>
function abrirModalRemover(url, nome) {
    document.getElementById('modalRemover').style.display = 'flex';
    document.getElementById('modalNomeUsuario').textContent = nome;
    document.getElementById('modalLinkRemover').href = url;
}
function fecharModalRemover() {
    document.getElementById('modalRemover').style.display = 'none';
}
document.getElementById('modalRemover').addEventListener('click', function(e) {
    if (e.target === this) fecharModalRemover();
});
</script>
                {% endif %}
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}