{% extends "base.html" %}
{% block title %}Logs{% endblock %}
{% block page_title %}Logs{% endblock %}
{% block content %}
<div class="table-wrap">
    <h3><i class="fas fa-history"></i> Registro de atividades</h3>
    <table>
        <thead><tr><th>Usuário</th><th>Ação</th><th>Data</th><th>Status</th></tr></thead>
        <tbody>
            {% for log in logs %}
            <tr>
                <td><i class="fas fa-user-circle"></i> {{ log.usuario }}</td>
                <td>{{ log.acao }}</td>
                <td>{{ log.data }}</td>
                <td><span class="status {{ 'active' if log.status == 'Sucesso' else 'inactive' }}">{{ log.status }}</span></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}